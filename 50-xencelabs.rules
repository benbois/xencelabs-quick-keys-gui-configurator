# Xencelabs Quick Keys - HID access (hidraw)
KERNEL=="hidraw*", ATTRS{idVendor}=="28bd", ATTRS{idProduct}=="5202", MODE="0666"
KERNEL=="hidraw*", ATTRS{idVendor}=="28bd", ATTRS{idProduct}=="5203", MODE="0666"
KERNEL=="hidraw*", ATTRS{idVendor}=="28bd", ATTRS{idProduct}=="5204", MODE="0666"

# Xencelabs Quick Keys - USB (fallback)
SUBSYSTEM=="usb", ATTRS{idVendor}=="28bd", ATTRS{idProduct}=="5202", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTRS{idVendor}=="28bd", ATTRS{idProduct}=="5203", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTRS{idVendor}=="28bd", ATTRS{idProduct}=="5204", MODE="0666", GROUP="plugdev"

# Virtual keyboard (uinput) - required for key injection
KERNEL=="uinput", MODE="0666", GROUP="input"
